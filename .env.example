# Nebius Token Factory (OpenAI-compatible API)
NEBIUS_API_KEY=...
# Optional: defaults to https://api.tokenfactory.nebius.com/v1/
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# Optional: defaults to nvidia/Nemotron-3-Nano-Omni
# NEBIUS_MODEL=nvidia/Nemotron-3-Nano-Omni

# Vision model for default PDF ingest (PDF → PNG per page → VLM). Required unless you use “Skip VLM” in the UI.
# Must support image inputs on your OpenAI-compatible base URL (e.g. a Qwen-VL or other multimodal slug).
# NEBIUS_VL_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Optional caps for vision ingest (defaults shown)
# PDF_VL_MAX_PAGES=25
# PDF_VL_DPI=150

ZEP_API_KEY=...
