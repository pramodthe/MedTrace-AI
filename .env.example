# Fireworks AI (OpenAI-compatible chat + vision)
# Docs: https://docs.fireworks.ai — endpoint matches OpenAI SDK / LangChain ChatOpenAI.
FIREWORKS_API_KEY=...
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1/
# Chat / agents — pick any serverless text model your key can access (see https://fireworks.ai/models ).
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
# PDF vision ingest — must be multimodal on your account (often different from chat-only models).
FIREWORKS_VL_MODEL=accounts/fireworks/models/kimi-k2p5
# Qwen3-style models may put CoT in reasoning_content; ``none`` keeps answers in message content.
FIREWORKS_REASONING_EFFORT=none
# PDF vision transport: chat = /v1/chat/completions (works with kimi-k2p5). completions = /v1/completions + <image> (Qwen-style).
FIREWORKS_VLM_API=chat
# FIREWORKS_VLM_COMPLETIONS_TIMEOUT=120

# Optional caps for vision ingest (defaults shown)
# PDF_VL_MAX_PAGES=25
# PDF_VL_DPI=150

ZEP_API_KEY=...

# Apply clinical ontology to Zep once per Streamlit session (project-wide). Set false to skip automatic registration.
AUTO_APPLY_ZEP_ONTOLOGY=true

# InsForge — durable document registry, app metadata, and Storage.
# Used by both apps/streamlit_app.py and the FastAPI service that backs the React Frontend.
# Get values from `.insforge/project.json` and `npx @insforge/cli secrets get ANON_KEY`.
INSFORGE_URL=https://your-appkey.us-east.insforge.app
INSFORGE_ANON_KEY=                    # public anon JWT (used by Frontend SDK + FastAPI reads)
INSFORGE_API_KEY=                     # server-side only; never expose in frontend bundles
INSFORGE_PROFILE_ID=                  # uuid = public.profiles.id (single-demo-profile mode)
INSFORGE_DOCUMENTS_BUCKET=medtrace-documents

# FastAPI service that backs the React Frontend (apps/api/main.py).
# Comma-separated list of allowed browser origins for CORS.
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Langtrace (optional) — traces LangChain + LangGraph / Deep Agents; get a key at https://langtrace.ai
# LANGTRACE_API_KEY=
# LANGTRACE_SERVICE_NAME=medtrace-agent
# LANGTRACE_API_HOST=              # self-hosted only; default https://langtrace.ai/

# LangSmith (optional alternative to Langtrace; LangChain docs — do not enable both unless intended)
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=medtrace-agent

# PubMed E-utilities (optional; used by Clinical reasoning Deep Agent)
# NCBI recommends setting your email; optional API key increases rate limits.
# NCBI_EMAIL=you@example.com
# NCBI_API_KEY=...
