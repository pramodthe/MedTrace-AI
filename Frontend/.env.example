# Vite injects VITE_* env vars into the browser bundle.
# Copy this file to `.env.local` and fill in real values.

# InsForge backend (linked project — see ../.insforge/project.json + `npx @insforge/cli secrets get ANON_KEY`).
VITE_INSFORGE_URL="https://your-appkey.us-east.insforge.app"
VITE_INSFORGE_ANON_KEY="<anon JWT from `npx @insforge/cli secrets get ANON_KEY`>"

# FastAPI service (apps/api/main.py). Defaults to http://localhost:8000 if unset.
VITE_API_BASE_URL="http://localhost:8000"

# Legacy AI Studio variables — unused by the new flow but kept so the existing
# vite.config.ts loadEnv resolves them without warnings.
GEMINI_API_KEY=""
APP_URL=""
